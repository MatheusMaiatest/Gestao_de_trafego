{
  "enabled": true,
  "name": "Auto Git Push ao Finalizar",
  "description": "Faz git add + commit + push automaticamente quando o agente termina de trabalhar, sem abrir novo chat",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "cd \"d:\\FERRAMENTAS KIRO\\TRÁFEGO\" && git add -A && git diff --cached --quiet || git commit -m \"auto: atualizar arquivos do projeto\" && git push origin main"
  }
}